{
  "version": 2,
  "public": true,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/extension.zip",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/zip"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=whatsapp-contact-exporter.zip"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/wa",
      "destination": "/index.html"
    },
    {
      "source": "/wa/:path*",
      "destination": "/:path*"
    }
  ]
}
