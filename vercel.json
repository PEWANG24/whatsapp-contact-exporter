{
  "version": 2,
  "name": "whatsapp-contact-exporter",
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/wa",
      "dest": "/public/index.html"
    },
    {
      "src": "/wa/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "headers": [
    {
      "source": "/extension.zip",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/zip"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=whatsapp-contact-exporter.zip"
        }
      ]
    }
  ]
}
